# Copy this file to .env and fill in your API keys.
# Never commit .env — it is in .gitignore.

# OpenAI (used for GPT-4o agent and/or simulated user)
OPENAI_API_KEY=sk-...

# Anthropic (used for Claude Sonnet agent)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override default user-simulation model
# USER_MODEL=gpt-4o
# USER_MODEL_PROVIDER=openai
